{
  "manifest_version": 3,
  "name": "Social Tools",
  "version": "1.5.17",
  "description": "Hapus repost / like TikTok & Instagram dari dashboard Social Tools — jalan di tab yang sudah login.",
  "key": "",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://*.tiktok.com/*",
    "https://www.instagram.com/*",
    "https://*.instagram.com/*",
    "https://socialtools.rizkiramadhan.biz.id/*",
    "http://localhost:3000/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://socialtools.rizkiramadhan.biz.id/*",
      "http://localhost:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": [
        "content-tiktok.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://*.instagram.com/*"
      ],
      "js": [
        "content-instagram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://socialtools.rizkiramadhan.biz.id/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Social Tools",
    "default_popup": "popup.html"
  }
}
