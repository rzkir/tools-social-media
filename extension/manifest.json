{
  "manifest_version": 3,
  "name": "Remove TikTok",
  "version": "1.5.5",
  "description": "Hapus repost / like / favorite TikTok dari dashboard — jalan di tab TikTok yang sudah login.",
  "key": "",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://*.tiktok.com/*",
    "https://socialtools.rizkiramadhan.biz.id/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://socialtools.rizkiramadhan.biz.id/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": [
        "content-tiktok.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://socialtools.rizkiramadhan.biz.id/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Remove TikTok",
    "default_popup": "popup.html"
  }
}
